// Initialize label distribution chart
function initializeLabelDistributionChart() {
    const canvas = document.getElementById('labelDistributionChart');
    if (!canvas || typeof Chart === 'undefined') return;
    if (Chart.getChart && Chart.getChart(canvas)) return;
    if (window.ChartDataLabels && Chart.register) {
        Chart.register(ChartDataLabels);
    }

    new Chart(canvas, {
        type: 'doughnut',
        data: {
            labels: ['Label 1', 'Label 2', 'Label 3'],
            datasets: [{
                data: [30, 40, 30],
                backgroundColor: ['#4e73df', '#1cc88a', '#36b9cc'],
                borderWidth: 0,
                borderRadius: 4
            }]
        },
        options: {
            cutout: '70%',
            plugins: {
                legend: { display: false },
                datalabels: {
                    color: '#ffffff',
                    font: { weight: '600', size: 14 },
                    formatter: (value, context) => {
                        const data = context.chart.data.datasets[0].data || [];
                        const total = data.reduce((sum, v) => sum + v, 0);
                        if (!total) return '';
                        const pct = Math.round((value / total) * 100);
                        return `${pct}%`;
                    }
                }
            },
            maintainAspectRatio: false
        }
    });
}

// Event Listeners
document.addEventListener('DOMContentLoaded', function() {
    // Initialize Lucide icons
    if (typeof lucide !== 'undefined') {
        lucide.createIcons();
    }
    
    // Set analyticsData for label page if not already set
    if (!window.analyticsData && document.getElementById('labelDistributionChart')) {
        window.analyticsData = {
            activeTab: 'label',
            dateRange: 'last7days'
        };
    }
    
    // Initialize label distribution chart if on label page
    if (document.getElementById('labelDistributionChart')) {
        initializeLabelDistributionChart();
    }
    
    // Date filter click handler
    const dateFilter = document.querySelector('.date-filter-section');
    if (dateFilter) {
        dateFilter.addEventListener('click', function() {
            // TODO: Implement date picker
            console.log('Date filter clicked');
        });
    }
});

const chatChartEl = document.getElementById("chatChart");
if (chatChartEl) {
const ctx = chatChartEl.getContext("2d");

function makeGradient(color) {
  const g = ctx.createLinearGradient(0, 0, 0, 400);
  g.addColorStop(0, color.replace("1)", "0.4)"));
  g.addColorStop(1, color.replace("1)", "0)"));
  return g;
}

const datasetsMap = {
  volume: [
    { label: "LINE", data: [15, 18, 14, 25, 20, 50, 48], color: "rgba(76,175,80,1)" },
    { label: "Facebook", data: [5, 15, 20, 16, 17, 25, 20], color: "rgba(33,150,243,1)" }
  ],

  missed: [
    { label: "LINE", data: [2, 5, 4, 3, 6, 10, 8], color: "rgba(244,67,54,1)" },
    { label: "Facebook", data: [1, 3, 2, 2, 5, 7, 6], color: "rgba(255,152,0,1)" }
  ],

  received: [
    { label: "LINE", data: [40, 45, 38, 50, 42, 70, 65], color: "rgba(33,150,243,1)" },
    { label: "Facebook", data: [30, 35, 33, 41, 39, 55, 48], color: "rgba(156,39,176,1)" }
  ],

  sent: [
    { label: "LINE", data: [35, 37, 32, 44, 38, 60, 55], color: "rgba(0,150,136,1)" },
    { label: "Facebook", data: [25, 30, 27, 33, 29, 40, 38], color: "rgba(63,81,181,1)" }
  ]
};

function updateLegendColors(type) {
  const legend = document.querySelector(".chart-legend");
  if (!legend || !datasetsMap[type]) return;

  const legendItems = legend.querySelectorAll(".legend-item");
  const datasets = datasetsMap[type];

  legendItems.forEach((item, index) => {
    const dot = item.querySelector(".legend-color");
    if (!dot || !datasets[index]) return;
    dot.style.backgroundColor = datasets[index].color;
  });
}

function buildDatasets(type) {
  return datasetsMap[type].map(d => ({
    label: d.label,
    data: d.data,
    borderColor: d.color,
    backgroundColor: makeGradient(d.color),
    fill: true,
    tension: 0.4,
    pointRadius: 0
  }));
}

const chart = new Chart(ctx, {
  type: "line",
  data: {
    labels: ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"],
    datasets: buildDatasets("volume")
  },
    options: {
        responsive: true,
        maintainAspectRatio: true,
        aspectRatio: 3.5,
        plugins: {
            legend: {
                position: "bottom"
            }
        },
        scales: {
            y: {
                beginAtZero: true,
                max: 60,

                ticks: {
                    stepSize: 15   // ⭐ THIS CONTROLS INTERVAL
                },

                grid: {
                    color: "#eee"
                }
            },

            x: {
                grid: {
                    display: false
                }
            }
        }
    }

});

updateLegendColors("volume");


// 🔥 TAB SWITCH LOGIC
document.querySelectorAll(".tabs .tab").forEach(btn => {
  btn.addEventListener("click", () => {
    document.querySelectorAll(".tabs .tab").forEach(t => t.classList.remove("active"));
    btn.classList.add("active");

    const type = btn.dataset.type;
    if (!datasetsMap[type]) return;

    chart.data.datasets = buildDatasets(type);
    chart.update();
    updateLegendColors(type);
  });
});
}
