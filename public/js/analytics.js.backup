// Donut Chart Functions
function createDonutChart(canvasId, percentage, color) {
    const ctx = document.getElementById(canvasId);
    if (!ctx) return;

    new Chart(ctx, {
        type: 'doughnut',
        data: {
            datasets: [{
                data: [percentage, 100 - percentage],
                backgroundColor: [color, '#f3f4f6'],
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '70%',
            plugins: {
                legend: {
                    display: false
                },
                tooltip: {
                    enabled: false
                }
            },
            animation: {
                animateRotate: true,
                animateScale: false
            }
        }
    });
}

function initializeDonutCharts() {
    // 10m Response Rate Donut Chart
    createDonutChart('donutChart10m', 50, '#ECF300');
    
    // 12h Response Rate Donut Chart
    createDonutChart('donutChart12h', 50, '#ECF300');
}

// Chart.js configuration
Chart.defaults.font.family = "'Nunito', 'Segoe UI', arial";
Chart.defaults.font.size = 12;
Chart.defaults.plugins.legend.display = false;
Chart.defaults.elements.line.borderWidth = 2;
Chart.defaults.elements.point.radius = 0;
Chart.defaults.elements.point.hoverRadius = 4;
Chart.defaults.plugins.tooltip.enabled = true;
Chart.defaults.plugins.tooltip.mode = 'index';
Chart.defaults.plugins.tooltip.intersect = false;

// Colors
const colors = {
    primary: '#4e73df',
    success: '#1cc88a',
    info: '#36b9cc',
    warning: '#f6c23e',
    danger: '#e74a3b',
    secondary: '#858796',
    light: '#f8f9fc',
    dark: '#5a5c69'
};

// Common chart options
const commonOptions = {
    responsive: true,
    maintainAspectRatio: false,
    plugins: {
        tooltip: {
            backgroundColor: 'rgb(255, 255, 255)',
            titleColor: colors.dark,
            bodyColor: colors.dark,
            borderColor: colors.secondary,
            borderWidth: 1,
            padding: 12,
            boxPadding: 6,
            usePointStyle: true,
            callbacks: {
                label: function(context) {
                    let label = context.dataset.label || '';
                    if (label) {
                        label += ': ';
                    }
                    label += context.parsed.y;
                    return label;
                }
            }
        }
    },
    scales: {
        x: {
            grid: {
                display: false
            },
            ticks: {
                color: colors.secondary
            }
        },
        y: {
            beginAtZero: true,
            grid: {
                color: colors.light,
                drawBorder: false
            },
            ticks: {
                color: colors.secondary,
                padding: 10
            }
        }
    }
};

// Global data storage
let analyticsData = {
    chat: null,
    agent: null,
    sales: null,
    label: null
};

// Fetch analytics data from backend
async function fetchAnalyticsData(tab = 'chat', dateRange = 'last_7_days') {
    try {
        const response = await fetch(`/api/analytics?tab=${tab}&date_range=${dateRange}`);
        const result = await response.json();
        
        if (result.success) {
            analyticsData[tab] = result;
            return result;
        } else {
            console.error('Failed to fetch analytics data:', result.message);
            return null;
        }
    } catch (error) {
        console.error('Error fetching analytics data:', error);
        return null;
    }
}

// Initialize charts when DOM is loaded
document.addEventListener('DOMContentLoaded', function() {
    // Fetch data and create charts
    initializeAnalyticsCharts();
    
    // Initialize donut charts
    initializeDonutCharts();
});

async function initializeAnalyticsCharts() {
    // Fetch chat performance data
    const chatData = await fetchAnalyticsData('chat');
    if (chatData) {
        createChatCharts(chatData);
    }
    
    // Fetch agent performance data
    const agentData = await fetchAnalyticsData('agent');
    if (agentData) {
        createAgentCharts(agentData);
    }
    
    // Fetch sales performance data
    const salesData = await fetchAnalyticsData('sales');
    if (salesData) {
        createSalesCharts(salesData);
    }
    
    // Fetch label usage data
    const labelData = await fetchAnalyticsData('label');
    createLabelCharts(labelData || { chartData: {} });
}

function createChatCharts(data) {
    createNewVsReturningChart(data.chatSummary);
    createCustomerChatsChart(data.chartData);
    createMissedChatsChart(data.chartData);
    createResponseRateChart(data.chartData);
    createTenMinResponseChart(data.chartData);
    createResponseTimeChart(data.chartData);
    createMessageReceivedChart(data.chartData);
    createMessageSentChart(data.chartData);
    createCustomerChatsByChannelChart(data.chartData);
    createMissedChatsByChannelChart(data.chartData);
    createAvgResponseRateChart(data.chartData);
    createAvgTenMinResponseRateChart(data.chartData);
}

function createAgentCharts(data) {
    createAgentCustomerChatsChart(data.chartData);
    createAgentMissedChatsChart(data.chartData);
}

function createSalesCharts(data) {
    // Sales charts will use the existing sales data structure
    createSalesRevenueChart(data.chartData);
    createSalesOrdersChart(data.chartData);
}

function createLabelCharts(data) {
    createLabelDistributionChart(data.chartData);
}

function createNewVsReturningChart(chatSummary) {
    const ctx = document.getElementById('newVsReturningChart');
    if (!ctx) return;

    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: ['New Chats', 'Returning Chats'],
            datasets: [{
                data: [chatSummary?.new_chats || 0, chatSummary?.returning_chats || 0],
                backgroundColor: [colors.info, colors.primary],
                borderWidth: 0
            }]
        },
        options: {
            cutout: '70%',
            plugins: {
                tooltip: {
                    enabled: true
                }
            }
        }
    });
}

function createLineChart(chartId, label, data, color, dates = null) {
    const ctx = document.getElementById(chartId);
    if (!ctx) return;

    const chartDates = dates || ['Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat', 'Sun'];
    
    new Chart(ctx, {
        type: 'line',
        data: {
            labels: chartDates,
            datasets: [{
                label: label,
                data: data,
                borderColor: color,
                backgroundColor: color,
                tension: 0.4,
                fill: false
            }]
        },
        options: commonOptions
    });
}

function createCustomerChatsChart(chartData) {
    createLineChart('customerChatsChart', 'Customer Chats', chartData?.total_chats || [0, 0, 0, 0, 0, 0, 0], colors.primary, chartData?.dates);
}

function createMissedChatsChart(chartData) {
    const missedChats = (chartData?.total_chats || []).map((total, index) => {
        const sent = chartData?.messages_sent?.[index] || 0;
        return Math.max(0, total - sent);
    });
    createLineChart('missedChatsChart', 'Missed Chats', missedChats, colors.danger, chartData?.dates);
}

function createResponseRateChart(chartData) {
    createLineChart('responseRateChart', 'Response Rate', chartData?.response_rates || [0, 0, 0, 0, 0, 0, 0], colors.success, chartData?.dates);
}

function createTenMinResponseChart(chartData) {
    const tenMinRates = (chartData?.response_rates || []).map(rate => Math.round(rate * 0.8));
    createLineChart('tenMinResponseChart', '10-Min Response', tenMinRates, colors.warning, chartData?.dates);
}

function createResponseTimeChart(chartData) {
    // Calculate average response time based on response rate (mock calculation for now)
    const responseTimes = (chartData?.response_rates || []).map(rate => {
        if (rate === 0) return 0;
        // Mock: lower response rate = longer response time
        return Math.round(100 - rate + Math.random() * 30);
    });
    createLineChart('responseTimeChart', 'Response Time', responseTimes, colors.info, chartData?.dates);
}

function createMessageReceivedChart(chartData) {
    createLineChart('messageReceivedChart', 'Messages Received', chartData?.messages_received || [0, 0, 0, 0, 0, 0, 0], colors.primary, chartData?.dates);
}

function createMessageSentChart(chartData) {
    createLineChart('messageSentChart', 'Messages Sent', chartData?.messages_sent || [0, 0, 0, 0, 0, 0, 0], colors.success, chartData?.dates);
}

function createCustomerChatsByChannelChart(chartData) {
    const ctx = document.getElementById('customerChatsByChannelChart');
    if (!ctx) return;

    const dates = chartData?.dates || ['07 Mar', '08 Mar', '09 Mar', '10 Mar', '11 Mar', '12 Mar', '13 Mar', '14 Mar'];
    
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: dates,
            datasets: [
                {
                    label: 'Facebook',
                    data: chartData?.facebook_chats || Array(dates.length).fill(0),
                    backgroundColor: colors.primary
                },
                {
                    label: 'Line',
                    data: chartData?.line_chats || chartData?.total_chats || Array(dates.length).fill(0),
                    backgroundColor: colors.success
                }
            ]
        },
        options: {
            ...commonOptions,
            scales: {
                x: {
                    stacked: true,
                    grid: {
                        display: false
                    }
                },
                y: {
                    stacked: true,
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1
                    }
                }
            }
        }
    });
}

