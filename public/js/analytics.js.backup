function createAvgTenMinResponseRateChart(chartData) {
    const ctx = document.getElementById('avgTenMinResponseRateChart');
    if (!ctx) return;

    const dates = chartData?.dates || ['07 Mar', '08 Mar', '09 Mar', '10 Mar', '11 Mar', '12 Mar', '13 Mar', '14 Mar'];
    
    new Chart(ctx, {
