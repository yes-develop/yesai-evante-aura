function createAgentCustomerChatsChart(chartData) {
    const ctx = document.getElementById('agentCustomerChatsChart');
    if (!ctx) return;

    const dates = chartData?.dates || ['07 Mar', '08 Mar', '09 Mar', '10 Mar', '11 Mar', '12 Mar', '13 Mar', '14 Mar'];
    
    // Create datasets for each agent
    const datasets = (chartData?.agents || []).map(agent => ({
        label: agent.name,
        data: agent.daily_chats || Array(dates.length).fill(0),
        backgroundColor: agent.color || colors.info
    }));
    
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: dates,
            datasets: datasets
        },
        options: {
            ...commonOptions,
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1
                    }
                }
            }
        }
    });
}

function createAgentMissedChatsChart(chartData) {
    const ctx = document.getElementById('agentMissedChatsChart');
    if (!ctx) return;

    const dates = chartData?.dates || ['07 Mar', '08 Mar', '09 Mar', '10 Mar', '11 Mar', '12 Mar', '13 Mar', '14 Mar'];
    
    // Create datasets for each agent (missed chats)
    const datasets = (chartData?.agents || []).map(agent => {
        const missedChats = (agent.daily_chats || []).map(chats => Math.round(chats * 0.2)); // Mock: 20% missed
        return {
            label: agent.name,
            data: missedChats,
            backgroundColor: agent.color || colors.info
        };
    });
    
    new Chart(ctx, {
        type: 'bar',
        data: {
            labels: dates,
            datasets: datasets
        },
        options: {
            ...commonOptions,
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1
                    }
                }
            }
        }
    });
}

function createLabelDistributionChart(chartData) {
    const ctx = document.getElementById('labelDistributionChart');
    if (!ctx) return;

    if (window.ChartDataLabels && Chart.register) {
        Chart.register(ChartDataLabels);
    }

    new Chart(ctx, {
        type: 'doughnut',
        data: {
            labels: chartData?.labels || ['Label 1', 'Label 2', 'Label 3'],
            datasets: [{
                data: chartData?.counts || [30, 40, 30],
                backgroundColor: chartData?.colors || [colors.primary, colors.success, colors.info],
                borderWidth: 0,
                borderRadius: 4
            }]
        },
        options: {
            cutout: '70%',
            plugins: {
                legend: {
                    display: false
                },
                datalabels: {
                    color: '#ffffff',
                    font: { weight: '600', size: 14 },
                    formatter: (value, context) => {
                        const data = context.chart.data.datasets[0].data || [];
                        const total = data.reduce((sum, v) => sum + v, 0);
                        if (!total) return '';
                        const pct = Math.round((value / total) * 100);
                        return `${pct}%`;
                    }
                }
            },
            layout: {
                padding: 20
            },
            maintainAspectRatio: false
        }
    });
}

function createSalesRevenueChart(chartData) {
    const ctx = document.getElementById('salesRevenueChart');
    if (!ctx) return;

    const dates = chartData?.dates || ['07 Mar', '08 Mar', '09 Mar', '10 Mar', '11 Mar', '12 Mar', '13 Mar'];
    
